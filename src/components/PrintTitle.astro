---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';
---

<Default {...Astro.props}><slot /></Default>

<div class="print-utility-bar no-print">
  <button onclick="window.print()" class="print-meta-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 6 2 18 2 18 9"></polyline>
      <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
      <rect x="6" y="14" width="12" height="8"></rect>
    </svg>
    <span>Print Worksheet</span>
  </button>
</div>

<style>
  .print-utility-bar {
    display: flex;
    justify-content: flex-end; /* Pushes button to the right */
    width: 100%;
    margin-top: -0.5rem; /* Pulls it closer to the title */
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .print-meta-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    
    /* Minimalist Typography */
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    transition: color 0.2s ease;
  }

  .print-meta-btn:hover {
    color: var(--sl-color-text-accent);
  }

  .print-meta-btn svg {
    opacity: 0.6;
  }

  .print-meta-btn:hover svg {
    opacity: 1;
    stroke: var(--sl-color-text-accent);
  }
</style>