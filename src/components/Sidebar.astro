---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Sidebar.astro';
import ExamTimer from './ExamTimer.jsx'; 

const greetings = [
  "Not another maths page...",
  "Calculations & Egg Tarts",
  "The Variable Graveyard",
  "𝜋: Tasty, but Infinite",
  "Solve for Why?",
  "Keep Calm and Carry One",
  "Warning: High Logic Zone",
  "𝑥 is missing. Call the police.",
  "Square Roots & Salty Tears",
  "Fancy a bit of Algebra?",
  "Please mind the gap.",
  "Humidity: 99%. Brain: 1%."
];

const randomGreeting = greetings[Math.floor(Math.random() * greetings.length)];

const isIB = Astro.url.pathname.includes('/ib-aisl');
const isTeacher = import.meta.env.PUBLIC_TEACHER_MODE === 'true';
const currentSidebar = Astro.locals.starlightRoute?.sidebar || Astro.props.sidebar || [];

const filteredSidebar = currentSidebar.filter(item => {
  if (isTeacher) return true;
  const folderName = item.label || '';
  if (isIB) {
    return folderName.includes('IB Mathematics AI SL');
  } else {
    return folderName.includes('IGCSE Mathematics');
  }
});

if (Astro.locals.starlightRoute) {
  Astro.locals.starlightRoute.sidebar = filteredSidebar;
}

const newProps = { ...Astro.props, sidebar: filteredSidebar };
---

<ExamTimer client:only="react" />

<div class="sidebar-container">
  {/* Sticky Header with Fixed Height */}
  <div class="sidebar-sticky-wrapper">
    <div id="dynamic-greeting" class="sidebar-header-hint">
      {randomGreeting} 
    </div>
  </div>

  <div class="sidebar-content">
    <Default {...newProps}><slot /></Default>
  </div>
</div>

<style>
  .sidebar-container {
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* FIXED HEIGHT WRAPPER: Prevents content from jumping */
  .sidebar-sticky-wrapper {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--sl-color-bg-sidebar, var(--sl-color-bg));
    height: 3rem; /* Locked height */
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .sidebar-header-hint {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    font-weight: bold;
    color: var(--sl-color-gray-3); 
    padding: 0 1rem;
    opacity: 0.8;
    font-family: var(--__sl-font-mono);
    /* Prevent text wrapping from changing the height */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-content {
    flex: 1;
    /* This ensures the scroll stays within the content area */
  }

  :global([data-theme='dark']) .sidebar-container {
    background: linear-gradient(
      to bottom, 
      transparent, 
      rgba(var(--sl-color-accent-low-rgb), 0.05)
    );
  }
</style>

<script is:inline>
  function applyDeviceContext() {
    const greetingEl = document.getElementById('dynamic-greeting');
    if (!greetingEl) return;

    const hour = new Date().getHours(); 
    if (hour >= 23 || hour < 4) {
      greetingEl.innerText = "🌙 Off to bed. Maths can wait.";
    } else if (hour < 7) {
      greetingEl.innerText = "☕ Why are you awake?";
    }
  }

  applyDeviceContext();
  document.addEventListener('astro:after-swap', applyDeviceContext);

  setInterval(() => {
    const container = document.querySelector('.sidebar-container');
    if (!container) return;
    const x = document.createElement('div');
    x.innerText = 'x';
    x.style.position = 'absolute';
    x.style.left = '-20px';
    x.style.top = Math.random() * 80 + '%';
    x.style.transition = 'all 10s linear';
    x.style.opacity = '0.3';
    x.style.pointerEvents = 'none';
    x.style.color = 'var(--sl-color-accent)';
    container.appendChild(x);
    setTimeout(() => { x.style.left = '110%'; }, 100);
    setTimeout(() => x.remove(), 10500);
  }, 300000); 
</script>