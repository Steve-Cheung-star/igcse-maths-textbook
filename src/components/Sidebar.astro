---
// src/components/Sidebar.astro
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Sidebar.astro';
import { getRandomGreeting, filterSidebar } from '../utils/sidebarHelpers';
import ExamTimer from './ExamTimer.jsx'; // <-- Added Timer Import

const randomGreeting = getRandomGreeting();
const isTeacher = import.meta.env.PUBLIC_TEACHER_MODE === 'true';
const currentSidebar = Astro.locals.starlightRoute?.sidebar || Astro.props.sidebar || [];

const filteredSidebar = filterSidebar(currentSidebar, Astro.url, isTeacher);

if (Astro.locals.starlightRoute) {
  Astro.locals.starlightRoute.sidebar = filteredSidebar;
}

const newProps = { ...Astro.props, sidebar: filteredSidebar };
---

<div class="sidebar-container">
  <div class="sidebar-sticky-wrapper">
    <div id="dynamic-greeting" class="sidebar-header-hint">{randomGreeting}</div>
  </div>
  
  <div class="sidebar-content">
    <Default {...newProps}><slot /></Default>
  </div>

  <div class="global-timer-container">
    <ExamTimer client:load />
  </div>
</div>

<style>
  .sidebar-container { 
    position: relative; 
  }
  
  .sidebar-sticky-wrapper { 
    position: sticky; 
    top: 0; 
    z-index: 10; 
    height: 3rem; 
    display: flex; 
    align-items: center; 
    background: var(--sl-color-bg-sidebar, var(--sl-color-bg));
    border-bottom: 1px solid var(--sl-color-hairline); 
  }
  
  .sidebar-header-hint { 
    font-size: 0.65rem; 
    text-transform: uppercase; 
    letter-spacing: 0.05rem; 
    font-weight: bold; 
    color: var(--sl-color-gray-3); 
    padding: 0 1rem; 
    opacity: 0.8; 
    font-family: var(--__sl-font-mono); 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
  }

  /* Added Timer Styles */
  .global-timer-container {
    padding: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-nav);
    margin-top: auto; /* Pushes the timer to the bottom if there's extra vertical space */
  }
</style>