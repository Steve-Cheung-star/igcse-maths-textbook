---
/* src/components/FormulaBox.astro */
interface Props {
  title?: string;
  formula?: string;
}

const { title = "Key Formula", formula } = Astro.props;
---

<div class="formula-container">
  <div class="formula-header">
    <span class="formula-icon">∑</span>
    <span class="formula-title math-title" set:html={title} />
  </div>
  <div class="formula-content">
    {formula ? (
      <div class="formula-math">
        $${formula}$$
      </div>
    ) : (
      <slot />
    )}
  </div>
</div>

<script is:inline>
  // This is a browser-only "fire and forget" function
  (function() {
    const render = () => {
      if (window.renderMathInElement) {
        window.renderMathInElement(document.body, {
          delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$', right: '$', display: false}
          ],
          throwOnError: false
        });
      }
    };
    render();
    document.addEventListener('astro:page-load', render);
    document.addEventListener('astro:after-swap', render);
  })();
</script>

<style>
  /* Use your exact styles here - they don't affect memory */
  .formula-container {
    margin: 2rem 0;
    border: 2px solid #1e293b;
    border-left: 6px solid #1e293b;
    border-radius: 8px;
    background: #ffffff;
    overflow: hidden; 
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }
  .formula-header {
    background: #1e293b;
    color: #f8fafc;
    padding: 0.6rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 700;
    text-transform: uppercase; 
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }
  .formula-title :global(.katex) {
    text-transform: none !important;
    font-size: 1.1rem; 
    letter-spacing: normal;
  }
  .formula-icon { font-size: 1.25rem; color: #38bdf8; }
  .formula-content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.3rem;
    color: #000000 !important; 
    font-weight: 500;
    text-align: center;
  }
  .formula-content :global(.katex) {
    color: #000000 !important;
    text-shadow: 0.15px 0 0 #000000; 
  }
</style>