---
interface Props {
  title?: string;
}

const { title = "TEACHER CHECKPOINT" } = Astro.props;
---

<div class="teacher-note">
  <div class="teacher-note__header">
    <span class="teacher-note__icon">🎓</span>
    <span class="teacher-note__title">{title}</span>
  </div>
  
  <div class="teacher-note__content">
    <slot />
  </div>
</div>

<style>
  /* --- STUDENT VIEW (Hidden) --- */
  .teacher-note {
    display: none; 
    margin: 2rem 0;
    padding: 1.25rem;
    background-color: #fff1f0;
    border: 2px dashed #ff4d4f;
    border-radius: 12px;
  }

  /* --- BENTO MODE REVEAL --- */
  /* This targets the <html> attribute we set in the config script */
  :global(html[data-mode="bento"]) .teacher-note {
    display: block !important;
    animation: slideIn 0.4s ease-out;
  }

  .teacher-note__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid #ffa39e;
    padding-bottom: 0.5rem;
  }

  .teacher-note__icon {
    font-size: 1.2rem;
  }

  .teacher-note__title {
    font-weight: bold;
    color: #cf1322;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
  }

  .teacher-note__content {
    color: #000;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>