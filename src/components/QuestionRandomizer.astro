---
/* QuestionRandomizer.astro */
---

<div class="randomizer-card">
  <div class="controls-row">
    <div class="input-group">
      <label for="search-text">Search Exam Bank</label>
      <input type="text" id="search-text" placeholder="Try 'Circle Theorems'" />
    </div>

    <button id="randomise-btn" class="primary-btn">
      <span class="btn-text">Randomise</span>
    </button>
  </div>

  <div id="display-area" class="display-area">
    <p id="status-text" class="status-message"></p>

    <div id="content-card" class="hidden">
      <div class="meta-header">
        <span id="res-topic" class="badge">Topic</span>
        <span id="res-subtopic" class="badge secondary">Subtopic</span>
      </div>

      <div class="image-wrapper">
        <p class="image-label">Question:</p>
        <img id="question-img" src="" alt="Question Image" />
      </div>

      <details class="ms-details">
        <summary>View Mark Scheme</summary>
        <div class="image-wrapper ms-box">
          <img id="ms-img" src="" alt="Mark Scheme Image" />
        </div>
      </details>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  
  const API_BASE_URL = "https://igcse-exam-generator-production.up.railway.app";
  const API_KEY = import.meta.env.PUBLIC_API_KEY;

  const btn = document.getElementById("randomise-btn");
  const searchInput = document.getElementById("search-text");
  const status = document.getElementById("status-text");
  const contentCard = document.getElementById("content-card");

  const resTopic = document.getElementById("res-topic");
  const resSubtopic = document.getElementById("res-subtopic");
  const qImg = document.getElementById("question-img");
  const msImg = document.getElementById("ms-img");
  const msDetails = document.querySelector(".ms-details");

  // Keep track of object URLs so we can clean up memory on each new search
  let activeBlobUrls = [];

  // Helper function to fetch images with the API Key and return a renderable Object URL
  async function loadSecureImage(url) {
  // Force https if the backend accidentally sent http
  const secureUrl = url.replace("http://", "https://");
  
  const response = await fetch(secureUrl, {
    headers: {
      "x-api-key": API_KEY,
    },
  });
    
    if (!response.ok) {
        throw new Error("Failed to load secure image from server.");
    }
    
    const blob = await response.blob();
    const objectUrl = URL.createObjectURL(blob);
    activeBlobUrls.push(objectUrl); // Save for cleanup later
    return objectUrl;
  }

  btn.addEventListener("click", async () => {
    const term = searchInput.value.trim();

    if (msDetails) msDetails.open = false;

    btn.disabled = true;
    status.textContent = "🔍 Searching...";
    contentCard.classList.add("hidden");

    // Clean up old memory to prevent memory leaks in the browser
    activeBlobUrls.forEach(url => URL.revokeObjectURL(url));
    activeBlobUrls = [];

    try {
      const url = new URL(`${API_BASE_URL}/random-question`);
      if (term) url.searchParams.append("subtopic", term);

      // 1. Fetch the JSON data (IDs and URLs)
      const response = await fetch(url, {
        headers: {
          "x-api-key": API_KEY,
        },
      });

      if (!response.ok) {
        if (response.status === 429) throw new Error("Too many requests. Please wait a minute.");
        if (response.status === 403) throw new Error("Unauthorized access.");
        throw new Error(term ? `No results for "${term}"` : "Database is empty.");
      }

      const data = await response.json();

      resTopic.textContent = data.topic;
      resSubtopic.textContent = data.subtopic;

      // 2. Handle Multiple Question Images securely via Blobs
      const qWrapper = qImg.parentElement;
      qWrapper.querySelectorAll(".extra-q-img").forEach((el) => el.remove());
      
      if (data.question_urls.length > 0) {
          qImg.src = await loadSecureImage(data.question_urls[0]);
          
          for (let i = 1; i < data.question_urls.length; i++) {
              const newImg = qImg.cloneNode();
              newImg.id = "";
              newImg.src = await loadSecureImage(data.question_urls[i]);
              newImg.classList.add("extra-q-img");
              newImg.style.marginTop = "1rem";
              qWrapper.appendChild(newImg);
          }
      } else {
          qImg.src = "";
      }

      // 3. Handle Multiple Mark Scheme Images securely via Blobs
      const msWrapper = msImg.parentElement;
      msWrapper.querySelectorAll(".extra-ms-img").forEach((el) => el.remove());
      
      if (data.ms_urls.length > 0) {
          msImg.src = await loadSecureImage(data.ms_urls[0]);
          
          for (let i = 1; i < data.ms_urls.length; i++) {
              const newImg = msImg.cloneNode();
              newImg.id = "";
              newImg.src = await loadSecureImage(data.ms_urls[i]);
              newImg.classList.add("extra-ms-img");
              newImg.style.marginTop = "1rem";
              msWrapper.appendChild(newImg);
          }
      } else {
          msImg.src = "";
      }

      contentCard.classList.remove("hidden");
      status.textContent = "";
    } catch (err) {
      status.textContent = `❌ ${err.message}`;
    } finally {
      btn.disabled = false;
    }
  });

  searchInput.addEventListener("keypress", (e) => {
    if (e.key === "Enter") btn.click();
  });
</script>

<style>
  .randomizer-card {
    /* ☀️ LIGHT MODE VARIABLES (Default) */
    --card-bg: #ffffff;
    --card-border: #e5e7eb;
    --card-text: #1f2937;
    --shadow-color: rgba(0, 0, 0, 0.1);
    --label-text: #4b5563;
    --input-bg: #f9fafb;
    --input-border: #f3f4f6;
    --input-text: #111827; /* Explicitly set so it never vanishes! */
    --btn-bg: #111827;
    --btn-hover: #1f2937;
    --btn-text: #ffffff;
    --badge-bg: #dbeafe;
    --badge-text: #1e40af;
    --badge-sec-bg: #f3f4f6;
    --badge-sec-text: #4b5563;
    --img-bg: #fcfcfc;
    --img-border: #f1f1f1;
    --divider: #f9fafb;
    --link: #3b82f6;

    background: var(--card-bg);
    border: 1px solid var(--card-border);
    color: var(--card-text);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 10px 15px -3px var(--shadow-color);
    max-width: 850px;
    margin: 2rem auto;
    font-family: "Inter", system-ui, sans-serif;
  }

  /* 🌙 DARK MODE VARIABLES (Triggered by Starlight) */
  :global([data-theme="dark"]) .randomizer-card {
    --card-bg: #1c1e24;
    --card-border: #343841;
    --card-text: #e2e8f0;
    --shadow-color: rgba(0, 0, 0, 0.3);
    --label-text: #9ca3af;
    --input-bg: #0d0f12;
    --input-border: #2d313a;
    --input-text: #ffffff;
    --btn-bg: #3b82f6;
    --btn-hover: #2563eb;
    --btn-text: #ffffff;
    --badge-bg: #1e3a8a;
    --badge-text: #bfdbfe;
    --badge-sec-bg: #374151;
    --badge-sec-text: #d1d5db;
    --img-bg: #111827;
    --img-border: #374151;
    --divider: #374151;
    --link: #60a5fa;
  }

  /* --- APPLYING THE VARIABLES --- */
  
  .controls-row {
    display: flex;
    gap: 12px;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .controls-row {
      flex-direction: column;
      align-items: stretch;
    }
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--label-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  input {
    padding: 12px 16px;
    border: 2px solid var(--input-border);
    background: var(--input-bg);
    color: var(--input-text);
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.2s;
    outline: none;
  }

  input:focus {
    border-color: var(--link);
    background: var(--card-bg);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
  }

  .primary-btn {
    background: var(--btn-bg);
    color: var(--btn-text);
    border: none;
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.1s, background 0.2s;
    height: 48px;
  }

  .primary-btn:hover {
    background: var(--btn-hover);
  }
  
  .primary-btn:active {
    transform: scale(0.98);
  }
  
  .primary-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .hidden {
    display: none;
  }

  .meta-header {
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .badge.secondary {
    background: var(--badge-sec-bg);
    color: var(--badge-sec-text);
  }

  .image-wrapper {
    background: var(--img-bg);
    padding: 1.5rem;
    border: 1px solid var(--img-border);
    border-radius: 12px;
    margin-bottom: 1.5rem;
  }

  .image-label {
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--card-text);
    font-size: 0.9rem;
  }

  img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    /* Keeps transparent exam images readable in both themes */
    background: #ffffff; 
    padding: 1rem;
    box-sizing: border-box;
  }

  .ms-details {
    border-top: 2px solid var(--divider);
    padding-top: 1rem;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--link);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  summary::before {
    content: "▶";
    font-size: 0.7rem;
    transition: transform 0.2s;
  }

  details[open] summary::before {
    transform: rotate(90deg);
  }

  .status-message {
    color: var(--label-text);
    font-size: 0.95rem;
    text-align: center;
    padding: 1rem;
  }
</style>