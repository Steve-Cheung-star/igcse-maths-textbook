---
/* src/components/PrintButton.astro */
---
<button onclick="window.print()" class="print-btn no-print">
  <span>🖨️</span> Print
</button>

<style>
  .print-btn {
    margin-bottom: 1.5rem;
    padding: 0.6rem 1.2rem;
    background: #eee;
    border: 1px solid #ccc;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .print-btn:hover {
    background: #e0e0e0;
  }
</style>