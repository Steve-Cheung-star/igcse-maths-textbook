---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import FormulaBox from './FormulaBox.astro';

const { entry } = Astro.locals.starlightRoute;
const formula = entry?.data?.formula;
---

{/* 1. Render the normal Starlight Title first */}
<Default><slot /></Default>

{/* 2. ADD THIS: The Graceful Utility Bar */}
<div class="print-utility-bar no-print">
  <button onclick="window.print()" class="print-meta-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 6 2 18 2 18 9"></polyline>
      <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
      <rect x="6" y="14" width="12" height="8"></rect>
    </svg>
    <span>Print Page</span>
  </button>
</div>

{/* 3. Your existing Formula Box logic */}
{formula && (
  <div class="header-formula">
    <FormulaBox title="Key Formula">
      {formula}
    </FormulaBox>
  </div>
)}

<style>
  /* Your new utility bar styles */
  .print-utility-bar {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .print-meta-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    transition: color 0.2s ease;
  }

  .print-meta-btn:hover {
    color: var(--sl-color-text-accent);
  }

  /* Your existing formula styles */
  .header-formula {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }
</style>