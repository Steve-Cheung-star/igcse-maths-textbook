---
// src/components/ProjectorLayout.astro
import ProjectorToolbar from './ProjectorToolbar.astro';
---

<style is:global>

  /* STRICT MOBILE HIDE: Completely remove entry point for mobile */
  @media (max-width: 768px) {
    #wb-enter-projector {
      display: none !important;
    }
  }

  /* =========================================
     1. UI HIDING & CLEANUP
     ========================================= */
     
  /* CRITICAL: Override Starlight's sticky nav offset so it doesn't cause chopped text! */
  html[data-mode="bento"] {
    scroll-padding-top: 0 !important; 
  }

  html[data-mode="bento"] .sidebar, 
  html[data-mode="bento"] .right-sidebar, 
  html[data-mode="bento"] header, 
  html[data-mode="bento"] footer,
  html[data-mode="bento"] .pagination { display: none !important; }
  
  html[data-mode="bento"] .main-frame { padding: 0 !important; min-height: 100vh; }
  html[data-mode="bento"] .sl-container { max-width: 95vw !important; margin: 4rem auto !important; }
  html[data-mode="bento"] .sl-markdown-content { font-size: 1.8rem !important; line-height: 1.6; }
  html[data-mode="bento"] .katex-display { margin: 2.5rem 0 !important; font-size: 1.3em !important; }

  /* =========================================
     2. STANDARDIZED WIDTHS & SPACING
     ========================================= */
  html[data-mode="bento"] .sl-markdown-content > * { max-width: 850px !important; margin-left: 0 !important; margin-right: auto !important; box-sizing: border-box; }
  html[data-mode="bento"] .sl-markdown-content canvas,
  html[data-mode="bento"] .sl-markdown-content .sim-root { max-width: 100% !important; }

  /* Set margin-top to 90vh to push previous content away, and scroll-margin to snap cleanly */
  html[data-mode="bento"] .sl-markdown-content h2,
  html[data-mode="bento"] .sl-markdown-content h3 { 
    margin-top: 90vh !important; 
    padding-top: 0 !important; 
    scroll-margin-top: 2rem !important; /* Perfect 2rem gap from monitor edge */
    border-top: none !important; 
  }
  
  html[data-mode="bento"] .sl-markdown-content hr { 
    display: block !important; 
    margin-top: 90vh !important; 
    margin-bottom: 2rem !important; 
    padding: 0 !important; 
    height: 0 !important; 
    border: none !important; 
    background: transparent !important; 
    clear: both !important; 
  }
  
  html[data-mode="bento"] .sl-markdown-content h2:first-of-type { 
    margin-top: 2rem !important; 
  }
  html[data-mode="bento"] .sl-markdown-content { 
    padding-bottom: 80vh !important; 
  }
  
  /* =========================================
     3. NATIVE HARDWARE-ACCELERATED CURSORS
     ========================================= */
  html[data-mode="bento"][data-tool="laser"], 
  html[data-mode="bento"][data-tool="laser"] body,
  html[data-mode="bento"][data-tool="laser"] * { cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="7" fill="%23ff0000" stroke="white" stroke-width="2.5" box-shadow="0 0 10px red"/></svg>') 12 12, auto !important; }
  
  html[data-mode="bento"][data-tool="pen"] body { cursor: crosshair !important; }
  html[data-mode="bento"][data-tool="eraser"] body { cursor: cell !important; }

  /* =========================================
     4. OPTIMAL TYPOGRAPHY (Asides & Callouts)
     ========================================= */
  html[data-mode="bento"] .sl-markdown-content aside,
  html[data-mode="bento"] .sl-markdown-content .starlight-aside {
    float: none !important;
    clear: both !important;
    position: relative !important;
    display: block !important;
    width: 100% !important;
    max-width: 50ch !important; 
    margin-top: 2.5rem !important;
    margin-bottom: 2.5rem !important;
    margin-left: 0 !important;
    margin-right: auto !important;
  }

  html[data-mode="bento"] .sl-markdown-content p,
  html[data-mode="bento"] .sl-markdown-content ul,
  html[data-mode="bento"] .sl-markdown-content ol {
    max-width: 50ch !important;
  }
</style>

<ProjectorToolbar />

<script>
  // @ts-nocheck
  import { projectorStore } from '../store/projectorStore.js';

  function initLayout() {
    if (document.documentElement.dataset.layoutInit) return;
    document.documentElement.dataset.layoutInit = 'true';

    let previousBentoState = false;

    // Helper: Safely grab the closest heading section
    function getActiveAnchor() {
      const headers = Array.from(document.querySelectorAll('.sl-markdown-content h2, .sl-markdown-content h3'));
      if (headers.length === 0) return null;
      
      let activeAnchor = headers[0]; // Default to the first section
      
      for (const header of headers) {
        const rect = header.getBoundingClientRect();
        
        // BUG FIX: Instead of checking the whole top half of the screen,
        // we only care about headers that have reached the top reading area (~120px).
        // This prevents short, stacked sections from overwriting the correct anchor.
        if (rect.top <= 120) {
          activeAnchor = header;
        } else {
          // As soon as we see a header below our top reading threshold, we stop.
          // The previous header in the loop is guaranteed to be our active section.
          break; 
        }
      }
      return activeAnchor;
    }

    const enterBtn = document.getElementById('wb-enter-projector');
    if (enterBtn) {
      enterBtn.addEventListener('click', () => {
        if (window.innerWidth < 768) return; 
        projectorStore.setKey('isBento', true);
      });
    }

    projectorStore.subscribe((state) => {
      // Detect if we are toggling on/off
      if (state.isBento !== previousBentoState) {
        
        // Step A: Check if they are at the very top of the article
        const isAtTop = window.scrollY < 100;
        const anchor = getActiveAnchor();

        // Step B: Apply CSS changes
        if (state.isBento) {
          document.documentElement.setAttribute('data-mode', 'bento');
          document.documentElement.setAttribute('data-tool', state.tool);
        } else {
          document.documentElement.removeAttribute('data-mode');
          document.documentElement.removeAttribute('data-tool');
        }

        // Step C: Force exact alignment after a tiny delay to let CSS update
        setTimeout(() => {
          if (isAtTop) {
            window.scrollTo({ top: 0, behavior: 'instant' });
          } else if (anchor) {
            anchor.scrollIntoView({ behavior: 'instant', block: 'start' });
          }
        }, 30); 
        
        previousBentoState = state.isBento;
      } else {
        // If it was just a tool change
        if (state.isBento) {
          document.documentElement.setAttribute('data-tool', state.tool);
        }
      }
    });

    // Global Hotkey (Ctrl+Alt+P)
    window.addEventListener('keydown', (e) => {
      if (window.innerWidth < 768) return; 

      if ((e.ctrlKey || e.metaKey) && e.altKey && (e.key?.toLowerCase() === 'p' || e.code === 'KeyP')) {
        e.preventDefault(); 
        const isCurrentlyBento = projectorStore.get().isBento;
        projectorStore.setKey('isBento', !isCurrentlyBento);
      }
    }, true);
  }

  initLayout();
  document.addEventListener('astro:page-load', initLayout);
</script>