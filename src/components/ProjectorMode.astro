---
// src/components/ProjectorMode.astro
// Projector Mode: Whiteboard, Laser, and Presentation Spacing
---

<style>
  /* =========================================
     1. UI HIDING & CLEANUP
     ========================================= */
  :global(html[data-mode="bento"] .sidebar), 
  :global(html[data-mode="bento"] .right-sidebar), 
  :global(html[data-mode="bento"] header), 
  :global(html[data-mode="bento"] footer),
  :global(html[data-mode="bento"] .pagination) { display: none !important; }
  :global(html[data-mode="bento"] .main-frame) { padding: 0 !important; min-height: 100vh; }
  :global(html[data-mode="bento"] .sl-container) { max-width: 95vw !important; margin: 4rem auto !important; }
  :global(html[data-mode="bento"] .sl-markdown-content) { font-size: 1.8rem !important; line-height: 1.6; }
  :global(html[data-mode="bento"] .katex-display) { margin: 2.5rem 0 !important; font-size: 1.3em !important; }

  /* =========================================
     2. NATIVE HARDWARE-ACCELERATED LASER
     ========================================= */
  :global(html[data-mode="bento"][data-tool="laser"]), 
  :global(html[data-mode="bento"][data-tool="laser"] body),
  :global(html[data-mode="bento"][data-tool="laser"] *) {
    cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="7" fill="%23ff0000" stroke="white" stroke-width="2.5" box-shadow="0 0 10px red"/></svg>') 12 12, auto !important;
  }
  :global(html[data-mode="bento"][data-tool="pen"] body) { cursor: crosshair !important; }
  :global(html[data-mode="bento"][data-tool="eraser"] body) { cursor: cell !important; }

  /* =========================================
     3. STANDARDIZED WIDTHS & SPACING
     ========================================= */
  :global(html[data-mode="bento"] .sl-markdown-content > *) { max-width: 850px !important; margin-left: 0 !important; margin-right: auto !important; box-sizing: border-box; }
  :global(html[data-mode="bento"] .sl-markdown-content canvas),
  :global(html[data-mode="bento"] .sl-markdown-content .sim-root) { max-width: 100% !important; }

  :global(html[data-mode="bento"] .sl-markdown-content h2),
  :global(html[data-mode="bento"] .sl-markdown-content h3) { margin-top: 70vh !important; padding-top: 2rem !important; border-top: 3px dashed var(--sl-color-hairline) !important; }
  :global(html[data-mode="bento"] .sl-markdown-content hr) { display: block !important; margin-top: 70vh !important; margin-bottom: 2rem !important; padding: 0 !important; height: 0 !important; border: none !important; border-top: 3px dashed var(--sl-color-hairline) !important; background: transparent !important; clear: both !important; }
  :global(html[data-mode="bento"] .sl-markdown-content h2:first-of-type) { margin-top: 2rem !important; border-top: none !important; }
  :global(html[data-mode="bento"] .sl-markdown-content) { padding-bottom: 80vh !important; }

  /* =========================================
     4. WHITEBOARD CANVAS OVERLAY
     ========================================= */
  :global(#wb-canvas) { position: absolute; top: 0; left: 0; z-index: 999998; pointer-events: none; display: none; }
  :global(html[data-mode="bento"][data-tool="pen"] #wb-canvas),
  :global(html[data-mode="bento"][data-tool="eraser"] #wb-canvas) { pointer-events: auto; }
  :global(html[data-mode="bento"] #wb-canvas) { display: block; }
</style>

<script is:inline>
  (function() {
    // --- STATE & DATA ---
    const state = {
      isBento: false,
      isToolbarMinimized: false,
      tool: 'laser',
      color: 'rgba(0, 255, 255, 0.7)',
      strokes: [],
      redoStack: [],
      currentStroke: null,
      isDrawing: false,
    };

    const colors = {
      cyan: 'rgba(0, 255, 255, 0.75)',
      magenta: 'rgba(255, 0, 255, 0.75)',
      yellow: 'rgba(255, 255, 0, 0.75)',
      lime: 'rgba(57, 255, 20, 0.75)',
      white: 'rgba(255, 255, 255, 0.8)'
    };

    let canvas, ctx;

    // --- INITIALIZATION ---
    function initWhiteboard() {
      state.isBento = localStorage.getItem('whiteboard-mode') === 'bento';
      const savedStrokes = sessionStorage.getItem(`wb-strokes-${window.location.pathname}`);
      if (savedStrokes) { try { state.strokes = JSON.parse(savedStrokes); } catch(e){} }

      syncDOMState();
      injectUI();
      initCanvas();
      attachShortcuts();
      initDragAndToggleLogic();
    }

    function syncDOMState() {
      if (state.isBento) {
        document.documentElement.setAttribute('data-mode', 'bento');
        document.documentElement.setAttribute('data-tool', state.tool);
      } else {
        document.documentElement.removeAttribute('data-mode');
        document.documentElement.removeAttribute('data-tool');
      }
      updateUIButtons();
    }

    // --- CANVAS ENGINE ---
    function initCanvas() {
      if (document.getElementById('wb-canvas')) return;
      canvas = document.createElement('canvas');
      canvas.id = 'wb-canvas';
      document.body.appendChild(canvas);
      ctx = canvas.getContext('2d');

      const resizeCanvas = () => {
        if (!canvas) return;
        canvas.width = document.documentElement.scrollWidth;
        canvas.height = document.documentElement.scrollHeight;
        redrawAll(); 
      };
      
      if (!window.wbResizeAttached) {
        window.addEventListener('resize', resizeCanvas);
        window.wbResizeAttached = true;
      }
      setTimeout(resizeCanvas, 500); 
      canvas.addEventListener('mousedown', startDrawing);
      canvas.addEventListener('mousemove', draw);
      canvas.addEventListener('mouseup', stopDrawing);
      canvas.addEventListener('mouseout', stopDrawing);
    }

    function startDrawing(e) {
      if (state.tool !== 'pen' && state.tool !== 'eraser') return;
      state.isDrawing = true; state.redoStack = []; 
      const x = e.pageX; const y = e.pageY;
      state.currentStroke = { tool: state.tool, color: state.tool === 'eraser' ? 'rgba(0,0,0,1)' : state.color, points: [{x, y}] };
      ctx.beginPath(); ctx.moveTo(x, y); ctx.lineCap = 'round'; ctx.lineJoin = 'round';
      ctx.lineWidth = state.tool === 'eraser' ? 40 : 6; ctx.strokeStyle = state.currentStroke.color;
      ctx.globalCompositeOperation = state.tool === 'eraser' ? 'destination-out' : 'source-over';
    }

    function draw(e) {
      if (!state.isDrawing) return;
      const x = e.pageX; const y = e.pageY;
      state.currentStroke.points.push({x, y});
      ctx.lineTo(x, y); ctx.stroke();
    }

    function stopDrawing() {
      if (!state.isDrawing) return;
      state.isDrawing = false;
      if (state.currentStroke && state.currentStroke.points.length > 0) {
        state.strokes.push(state.currentStroke); saveStrokes();
      }
      state.currentStroke = null;
    }

    function redrawAll() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      state.strokes.forEach(stroke => {
        if (stroke.points.length === 0) return;
        ctx.beginPath(); ctx.moveTo(stroke.points[0].x, stroke.points[0].y); ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        ctx.lineWidth = stroke.tool === 'eraser' ? 40 : 6; ctx.strokeStyle = stroke.color;
        ctx.globalCompositeOperation = stroke.tool === 'eraser' ? 'destination-out' : 'source-over';
        stroke.points.forEach(pt => ctx.lineTo(pt.x, pt.y)); ctx.stroke();
      });
      ctx.globalCompositeOperation = 'source-over'; 
    }

    function saveStrokes() { sessionStorage.setItem(`wb-strokes-${window.location.pathname}`, JSON.stringify(state.strokes)); }

    // --- ACTIONS ---
    window.wbSetTool = function(tool) { state.tool = tool; document.documentElement.setAttribute('data-tool', state.tool); updateUIButtons(); };
    window.wbSetColor = function(colorKey) { state.color = colors[colorKey]; window.wbSetTool('pen'); updateUIButtons(); };
    window.wbUndo = function() { if (state.strokes.length > 0) { state.redoStack.push(state.strokes.pop()); redrawAll(); saveStrokes(); } };
    window.wbRedo = function() { if (state.redoStack.length > 0) { state.strokes.push(state.redoStack.pop()); redrawAll(); saveStrokes(); } };
    window.wbClear = function() { state.strokes = []; state.redoStack = []; redrawAll(); saveStrokes(); };

    window.toggleProjector = function() {
      state.isBento = !state.isBento;
      localStorage.setItem('whiteboard-mode', state.isBento ? 'bento' : 'normal');
      syncDOMState();
      if (state.isBento && canvas) { canvas.width = document.documentElement.scrollWidth; canvas.height = document.documentElement.scrollHeight; redrawAll(); }
    };

    // --- UI INJECTION ---
    function injectUI() {
      if (!document.getElementById('wb-nav-toggle')) {
        const navToggle = document.createElement('button');
        navToggle.id = 'wb-nav-toggle'; 
        navToggle.title = "Presentation Mode (Ctrl+Alt+P)"; 
        navToggle.onclick = window.toggleProjector;
        navToggle.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2" ry="2"></rect><path d="M8 3h8"></path><path d="M12 3v4"></path></svg>`;
        
        const themeSelect = document.querySelector('theme-select');
        if (themeSelect && themeSelect.parentNode) {
          themeSelect.parentNode.insertBefore(navToggle, themeSelect);
        } else {
          document.body.appendChild(navToggle);
          navToggle.classList.add('fallback-floating');
        }
      }

      if (document.getElementById('wb-portal')) return;
      const portal = document.createElement('div'); portal.id = 'wb-portal';
      
      portal.innerHTML = `
        <button id="wb-exit" onclick="window.toggleProjector()" title="Exit Projector Mode (Esc)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
        </button>

        <div id="wb-toolbar-wrapper" class="horizontal maximized">
          <button id="wb-fab-toggle" title="Minimize / Drag">
             <svg class="icon-min" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
             <div class="icon-drag" id="wb-dynamic-icon"></div>
          </button>
          
          <div id="wb-toolbar" class="toolbar-panel">
            <div class="tool-group">
              <button class="tool-btn" data-tool-btn="mouse" onclick="window.wbSetTool('mouse')" title="Mouse (1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="M13 13l6 6"/></svg>
              </button>
              <button class="tool-btn" data-tool-btn="laser" onclick="window.wbSetTool('laser')" title="Laser (2)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
              <button class="tool-btn" data-tool-btn="pen" onclick="window.wbSetTool('pen')" title="Pen (3)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
              </button>
              <button class="tool-btn" data-tool-btn="eraser" onclick="window.wbSetTool('eraser')" title="Eraser (4)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20H7L3 16C2.5 15.5 2.5 14.5 3 14L13 4C13.5 3.5 14.5 3.5 15 4L20 9C20.5 9.5 20.5 10.5 20 11L11 20H20V20Z"/><path d="M17 14L7 20"/></svg>
              </button>
            </div>
            
            <div class="divider"></div>
            
            <div class="tool-group colors">
              <button class="color-btn cyan" onclick="window.wbSetColor('cyan')"></button>
              <button class="color-btn magenta" onclick="window.wbSetColor('magenta')"></button>
              <button class="color-btn yellow" onclick="window.wbSetColor('yellow')"></button>
              <button class="color-btn lime" onclick="window.wbSetColor('lime')"></button>
            </div>

            <div class="divider"></div>

            <div class="tool-group">
              <button class="tool-btn action" onclick="window.wbUndo()" title="Undo (Ctrl+Z)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/></svg>
              </button>
              <button class="tool-btn action" onclick="window.wbRedo()" title="Redo (Ctrl+Shift+Z)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"/></svg>
              </button>
              <button class="tool-btn action clear" onclick="window.wbClear()" title="Clear All">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
            </div>
          </div>
        </div>

        <style>
          /* Top Nav Button */
          #wb-nav-toggle { background: transparent; border: none; cursor: pointer; padding: 0.5rem; margin-right: 0.5rem; color: var(--sl-color-text-accent, currentColor); opacity: 0.8; transition: opacity 0.2s; display: flex; align-items: center; justify-content: center; }
          #wb-nav-toggle:hover { opacity: 1; }
          #wb-nav-toggle.fallback-floating { position: fixed; top: 1rem; right: 5rem; z-index: 9999; }
          html[data-mode="bento"] #wb-nav-toggle { display: none; } 

          /* Subtle Exit Button */
          #wb-exit { position: fixed; top: 1.5rem; right: 1.5rem; z-index: 9999999; display: none; width: 40px; height: 40px; border-radius: 50%; border: none; background: var(--sl-color-bg-nav, rgba(0,0,0,0.5)); color: var(--sl-color-text, #fff); align-items: center; justify-content: center; cursor: pointer; opacity: 0.2; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.2); backdrop-filter: blur(4px); }
          #wb-exit:hover { opacity: 1; transform: scale(1.1); background: rgba(255,50,50,0.8); color: white; }
          html[data-mode="bento"] #wb-exit { display: flex; }

          /* Toolbar Wrapper */
          #wb-toolbar-wrapper { 
            position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
            z-index: 9999999; display: none; align-items: center; background: var(--sl-color-bg-nav);
            border: 1px solid var(--sl-color-hairline); border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3); backdrop-filter: blur(12px);
          }
          html[data-mode="bento"] #wb-toolbar-wrapper { display: flex; }

          /* Minimized State (Transparent Dynamic Tool Circle) */
          #wb-toolbar-wrapper.minimized { border-radius: 50%; padding: 0; background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-hairline); }
          #wb-toolbar-wrapper.minimized #wb-toolbar { display: none; }
          #wb-toolbar-wrapper.minimized #wb-fab-toggle { cursor: grab; color: var(--sl-color-text); width: 48px; height: 48px; }
          #wb-toolbar-wrapper.minimized #wb-fab-toggle:active { cursor: grabbing; }
          #wb-toolbar-wrapper.minimized .icon-min { display: none; }
          #wb-toolbar-wrapper.minimized .icon-drag { display: flex; align-items: center; justify-content: center; }
          
          /* Dynamic SVG sizing inside minimized button */
          #wb-dynamic-icon svg { width: 22px; height: 22px; }

          /* Maximized State (High-Visibility Minimize Button) */
          #wb-toolbar-wrapper.maximized #wb-fab-toggle { 
            cursor: pointer; 
            color: var(--sl-color-text); 
            background: var(--sl-color-hairline); 
            border-radius: 8px;
            padding: 0.4rem; 
            margin: 0.5rem;
            transition: background 0.2s, color 0.2s;
          }
          #wb-toolbar-wrapper.maximized #wb-fab-toggle:hover { background: var(--sl-color-text-accent); color: var(--sl-color-bg); }
          #wb-toolbar-wrapper.maximized .icon-min { display: block; }
          #wb-toolbar-wrapper.maximized .icon-drag { display: none; }

          /* FAB Toggle Button Reset */
          #wb-fab-toggle { background: transparent; border: none; display: flex; align-items: center; justify-content: center; }

          /* Orientation Logic */
          #wb-toolbar-wrapper.horizontal { flex-direction: row; padding-right: 0.5rem; }
          #wb-toolbar-wrapper.vertical { flex-direction: column; padding-bottom: 0.5rem; }

          /* Inner Toolbar Panels */
          .toolbar-panel { display: flex; align-items: center; padding: 0.5rem; gap: 0.5rem; }
          #wb-toolbar-wrapper.horizontal .toolbar-panel { flex-direction: row; padding-left: 0; }
          #wb-toolbar-wrapper.vertical .toolbar-panel { flex-direction: column; padding-top: 0; }

          .tool-group { display: flex; gap: 0.25rem; }
          #wb-toolbar-wrapper.horizontal .tool-group { flex-direction: row; }
          #wb-toolbar-wrapper.vertical .tool-group { flex-direction: column; }

          .divider { background: var(--sl-color-hairline); }
          #wb-toolbar-wrapper.horizontal .divider { width: 1px; height: 24px; margin: 0 0.25rem; }
          #wb-toolbar-wrapper.vertical .divider { width: 24px; height: 1px; margin: 0.25rem 0; }

          /* Tools Styling */
          .tool-btn { color: var(--sl-color-text); background: transparent; border: 1px solid transparent; border-radius: 6px; padding: 0.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
          .tool-btn:hover { background: var(--sl-color-hairline); }
          .tool-btn.active { background: var(--sl-color-text-accent); border-color: var(--sl-color-text-accent); color: var(--sl-color-bg); }
          .tool-btn.clear:hover { background: rgba(255,0,0,0.2); color: #ff4444; }
          
          /* Colors Styling */
          .color-btn { width: 24px; height: 24px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2); cursor: pointer; transition: transform 0.2s; }
          .color-btn:hover { transform: scale(1.2); }
          .color-btn.active { border-color: var(--sl-color-text); transform: scale(1.1); }
          .cyan { background: #00ffff; box-shadow: 0 0 8px #00ffff88; }
          .magenta { background: #ff00ff; box-shadow: 0 0 8px #ff00ff88; }
          .yellow { background: #ffff00; box-shadow: 0 0 8px #ffff0088; }
          .lime { background: #39ff14; box-shadow: 0 0 8px #39ff1488; }
          
          @media (max-width: 50rem) { #wb-toolbar-wrapper, #wb-exit { display: none !important; } }
        </style>
      `;
      document.body.appendChild(portal);
      updateUIButtons();
    }

    function updateUIButtons() {
      // Clear active states
      document.querySelectorAll('.tool-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.color-btn').forEach(btn => btn.classList.remove('active'));

      // Set Active Tool Button
      const activeToolBtn = document.querySelector(`[data-tool-btn="${state.tool}"]`);
      if (activeToolBtn) {
        activeToolBtn.classList.add('active');
        
        // Dynamically update the Minimized Drag Icon to match the current tool
        const dynamicIconContainer = document.getElementById('wb-dynamic-icon');
        if (dynamicIconContainer) {
          dynamicIconContainer.innerHTML = activeToolBtn.innerHTML;
        }
      }

      // Set Active Color Button
      const colorKey = Object.keys(colors).find(key => colors[key] === state.color);
      const activeColorBtn = document.querySelector(`.color-btn.${colorKey}`);
      if (activeColorBtn) {
        activeColorBtn.classList.add('active');
      }
    }

    // --- DRAG & TOGGLE LOGIC ---
    function initDragAndToggleLogic() {
      const wrapper = document.getElementById('wb-toolbar-wrapper');
      const fab = document.getElementById('wb-fab-toggle');
      if (!wrapper || !fab) return;

      let isDragging = false;
      let hasDragged = false;
      let startX, startY;

      fab.addEventListener('mousedown', (e) => {
        e.preventDefault(); 
        if (!state.isToolbarMinimized) return; 
        
        isDragging = true;
        hasDragged = false;
        const rect = wrapper.getBoundingClientRect();
        startX = e.clientX - rect.left;
        startY = e.clientY - rect.top;
        
        wrapper.style.transform = 'none';
        wrapper.style.bottom = 'auto';
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        hasDragged = true; 
        
        let newX = e.clientX - startX;
        let newY = e.clientY - startY;

        newX = Math.max(10, Math.min(newX, window.innerWidth - wrapper.offsetWidth - 10));
        newY = Math.max(10, Math.min(newY, window.innerHeight - wrapper.offsetHeight - 10));

        wrapper.style.left = `${newX}px`;
        wrapper.style.top = `${newY}px`;
      });

      document.addEventListener('mouseup', () => { isDragging = false; });

      fab.addEventListener('click', (e) => {
        if (hasDragged) return; 

        state.isToolbarMinimized = !state.isToolbarMinimized;
        
        if (state.isToolbarMinimized) {
          wrapper.classList.remove('maximized');
          wrapper.classList.add('minimized');
        } else {
          wrapper.classList.remove('minimized');
          wrapper.classList.add('maximized');

          const rect = wrapper.getBoundingClientRect();
          const screenWidth = window.innerWidth;
          
          if (rect.left < screenWidth * 0.2 || rect.left > screenWidth * 0.8) {
            wrapper.classList.remove('horizontal');
            wrapper.classList.add('vertical');
          } else {
            wrapper.classList.remove('vertical');
            wrapper.classList.add('horizontal');
          }
        }
      });
    }

    // --- SHORTCUTS & SCROLLING ---
    function attachShortcuts() {
      if (window.wbShortcutAttached) return;
      window.addEventListener('keydown', (e) => {
        const isBento = document.documentElement.getAttribute('data-mode') === 'bento';
        if ((e.ctrlKey || e.metaKey) && e.altKey && (e.key?.toLowerCase() === 'p' || e.code === 'KeyP')) {
          e.preventDefault(); e.stopImmediatePropagation(); window.toggleProjector(); return;
        }
        if (!isBento) return;
        if (e.key === 'Escape') { window.toggleProjector(); return; }
        if ((e.ctrlKey || e.metaKey) && e.key === 'z') { if (e.shiftKey) window.wbRedo(); else window.wbUndo(); e.preventDefault(); }
        if (e.key === '1') window.wbSetTool('mouse');
        if (e.key === '2') window.wbSetTool('laser');
        if (e.key === '3') window.wbSetTool('pen');
        if (e.key === '4') window.wbSetTool('eraser');

        if (state.isDrawing) return;
        const scrollAmount = window.innerHeight * 0.8;
        if (['ArrowRight', 'ArrowDown', 'PageDown'].includes(e.key)) { e.preventDefault(); window.scrollBy({ top: scrollAmount, behavior: 'smooth' }); }
        if (['ArrowLeft', 'ArrowUp', 'PageUp'].includes(e.key)) { e.preventDefault(); window.scrollBy({ top: -scrollAmount, behavior: 'smooth' }); }
      }, true); 
      window.wbShortcutAttached = true;
    }

    function safeInit() { if (document.body) initWhiteboard(); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', safeInit);
    else safeInit();
    document.addEventListener('astro:after-swap', safeInit);
    document.addEventListener('astro:page-load', safeInit);
  })();
</script>