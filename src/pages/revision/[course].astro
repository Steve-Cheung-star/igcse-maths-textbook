---
// src/pages/revision/[course].astro
import RevisionLayout from "../../layouts/RevisionLayout.astro";
import FlashcardEngine from "../../components/FlashcardEngine.jsx";

export const prerender = true;
export async function getStaticPaths() {
  return [{ params: { course: "igcse" } }, { params: { course: "ib-aisl" } }];
}

const { course } = Astro.params;

const courseMeta = {
  igcse: { name: "IGCSE Maths", color: "#f97316", icon: "🎓" },
  "ib-aisl": { name: "IB Maths AI SL", color: "#a855f7", icon: "🌍" },
};

const current = courseMeta[course] || {
  name: "Revision",
  color: "#f97316",
  icon: "📚",
};

let allCards = [];
try {
  const cardData = await import(`../../data/flashcards/${course}.json`);
  
  // Use import.meta.env.SITE if configured, otherwise fallback to localhost for dev
  // If you haven't set 'site' in astro.config.mjs, we can check the DEV mode:
  const isDev = import.meta.env.DEV;
  const baseUrl = isDev 
    ? "http://localhost:4321" 
    : "https://igcse-maths-textbook.vercel.app";
  
  allCards = cardData.default.map(card => ({
    ...card,
    // Prepend baseUrl only if lesson_url is a relative path (starts with /)
    lesson_url: card.lesson_url.startsWith('/') 
      ? `${baseUrl}${card.lesson_url}` 
      : card.lesson_url
  }));
  
} catch (e) {
  console.error("Could not find flashcard data", e);
  allCards = [];
}
---

<RevisionLayout title={`${current.name} Revision`}>
  <div class="rev-container">
    <header class="rev-header">
      <div class="header-top">
        <a
          href={`/${course}/course-outline`}
          class="exit-btn"
          onclick="if(history.length > 1){ history.back(); return false; }"
        >
          ← Exit Session
        </a>
        <p class="status">Session Active</p>
      </div>

      <div class="title-row">
        <span class="rev-icon">{current.icon}</span>
        <h1 style={`color: ${current.color}`}>{current.name}</h1>
      </div>
    </header>

    <main class="rev-main">
      {
        allCards.length > 0 ? (
          <FlashcardEngine
            client:only="react"
            cards={allCards}
            course={course}
          />
        ) : (
          <p>Loading cards...</p>
        )
      }
    </main>
  </div>
</RevisionLayout>

<style>
  .rev-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
    min-height: 100vh;
  }

  .rev-header {
    width: 100%;
    margin-bottom: 1rem;
  }
  .header-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.4rem;
  }
  .exit-btn {
    text-decoration: none;
    opacity: 0.6;
    font-size: 0.75rem;
    color: inherit;
    font-weight: 700;
  }
  .status {
    margin: 0;
    opacity: 0.4;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .rev-icon {
    font-size: 1.25rem;
  }
  .rev-header h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
  }
  .rev-main {
    width: 100%;
  }
</style>