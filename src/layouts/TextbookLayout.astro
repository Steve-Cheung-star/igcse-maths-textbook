---
const { frontmatter, url } = Astro.props;
let subject = frontmatter.subject || "General";
if (url?.includes('/math/')) subject = "Math";
if (url?.includes('/physics/')) subject = "Physics";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{frontmatter.title}</title>
    <style>
      /* This tells Pagefind: "If an element has this class, do NOT index it" */
      .katex-mathml, .katex-html, annotation, mtext, .MathJax_Preview {
        -pagefind-ignore: true; 
      }
      
      /* Explicitly tell Pagefind to ignore SVG paths but keep text */
      svg path, svg circle, svg rect, svg line, svg polyline, svg polygon {
        -pagefind-ignore: true;
      }
      
      svg text, svg tspan {
        -pagefind-ignore: false;
      }
    </style>
  </head>
  <body>

    <nav data-pagefind-ignore>
       <a href="/">Home</a>
    </nav>

    <main data-pagefind-body data-pagefind-filter={`subject:${subject}`}>
      
      <h1 data-pagefind-weight="10">{frontmatter.title}</h1>

      <article>
        <slot />
      </article>

    </main>

  </body>
</html>