---
const { frontmatter, url } = Astro.props;
// Folder-based subject detection
let subject = "General";
if (url?.includes('/math/')) subject = "Math";
if (url?.includes('/physics/')) subject = "Physics";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{frontmatter.title}</title>
    
    <style is:global>
      /* Hide all LaTeX/Math internal structures from the search index */
      .katex-mathml, 
      .katex-html, 
      .base, 
      .strut, 
      .mord, 
      .mspace, 
      .mrel,
      annotation {
        -pagefind-ignore: true !important;
      }

      /* Clean up SVG indexing: Ignore the "lines" but keep the "labels" */
      svg path, svg circle, svg rect, svg line, svg polyline, svg polygon, svg style, svg defs {
        -pagefind-ignore: true !important;
      }

      /* Ensure SVG text IS searchable */
      svg text, svg tspan {
        -pagefind-ignore: false !important;
      }
    </style>
  </head>
  <body>

    <nav data-pagefind-ignore>
       <a href="/">Home</a>
    </nav>

    <main data-pagefind-body data-pagefind-filter={`subject:${subject}`}>
      
      <h1 data-pagefind-weight="10">{frontmatter.title}</h1>

      <article>
        <slot />
      </article>

    </main>

  </body>
</html>